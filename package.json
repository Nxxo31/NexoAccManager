{
  "name": "nexoaccmanager",
  "version": "2.1.0",
  "description": "Open-source multi-account manager for gaming platforms — 100% local, no servers, no cloud",
  "main": "dist/main/main.js",
  "author": {
    "name": "NexoAccManager Contributors",
    "email": "nexoaccmanager@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "electron:dev": "vite-plugin-electron dev",
    "electron:build": "npm run build && electron-builder",
    "electron:preview": "electron-builder --dir",
    "test": "vitest",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^9.4.0",
    "electron-store": "^11.0.2",
    "i18next": "^26.3.1",
    "node-forge": "^1.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.30.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-toast": "^1.2.19",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^10.5.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.0",
    "vitest": "^1.0.0",
    "wait-on": "^7.2.0",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.nexoaccmanager.app",
    "productName": "NexoAccManager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NexoAccManager"
    }
  }
}
