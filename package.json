{
  "name": "nx-manager",
  "version": "3.4.0",
  "description": "Open-source multi-account manager for gaming platforms — 100% local, no servers, no cloud",
  "main": "dist/main/main.js",
  "author": {
    "name": "NexoAccManager Contributors",
    "email": "nexoaccmanager@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:browser": "BROWSER_ONLY=1 vite",
    "build": "tsc && vite build && electron-builder",
    "electron:dev": "vite-plugin-electron dev",
    "electron:build": "npm run build && electron-builder",
    "electron:preview": "electron-builder --dir",
    "test:unit": "vitest run",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern '*.config.*' --ignore-pattern 'playwright-*.js' --ignore-pattern 'public/**' --ignore-pattern 'dist/**'",
    "test:e2e:browser": "BROWSER_ONLY=1 playwright test tests/e2e-browser --config playwright.browser.config.ts",
    "test:visual": "BROWSER_ONLY=1 playwright test tests/visual --config playwright.browser.config.ts",
    "test:a11y:browser": "BROWSER_ONLY=1 playwright test tests/a11y-browser --config playwright.browser.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^9.4.0",
    "electron-store": "^11.0.2",
    "i18next": "^26.3.1",
    "node-forge": "^1.3.1",
    "react-i18next": "^17.0.8",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@deslint/eslint-plugin": "^0.10.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@radix-ui/react-dialog": "^1.1.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^10.5.0",
    "framer-motion": "^12.42.2",
    "happy-dom": "^20.10.6",
    "lucide-react": "^1.24.0",
    "msw": "^2.15.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.0",
    "vitest": "^4.1.10",
    "wait-on": "^7.2.0",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.nxmanager.app",
    "productName": "NX-Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NX-Manager"
    }
  }
}