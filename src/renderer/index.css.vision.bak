@import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap");

@tailwind base;
@tailwind components;
@tailwind utilities;

/* === DESIGN SYSTEM — Minimalista === */
:root {
  --primary: #DE350D;
  --primary-dark: #B22A0A;
  --primary-light: #FF5C33;
  --accent: #6347FF;
  --accent-light: #8B6FFF;
  --bg-dark: #0D0D0D;
  --bg-card: #141414;
  --bg-surface: #1A1A1A;
  --bg-elevated: #222222;
  --text-primary: #FFFFFF;
  --text-secondary: #A0A0A0;
  --text-tertiary: #6B6B6B;
  --success: #2ED573;
  --warning: #FFA502;
  --error: #FF4757;
  --border: #242424;
  --border-light: #333333;
  --font-size: 14px;
  --transition-duration: 150ms;
}

/* Tailwind compat vars */
:root {
  --color-primary: #DE350D;
  --color-secondary: #6347FF;
  --color-error: #FF4757;
  --color-warning: #FFA502;
  --color-info: #74b9ff;
  --color-dark-bg: #0D0D0D;
  --color-dark-primary: #141414;
  --color-text: #FFFFFF;
  --color-text-secondary: #A0A0A0;
}

.dark {
  --color-bg: var(--color-dark-bg);
  --color-card-bg: var(--color-dark-primary);
}

.light {
  --color-bg: #f5f6fa;
  --color-card-bg: white;
}

/* === BASE === */
body {
  background-color: var(--bg-dark);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  color: var(--text-primary);
  margin: 0;
  padding: 0;
  font-size: var(--font-size);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

#root, .container {
  height: 100vh;
}

/* === SCROLLBAR — Minimal === */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--border-light);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--text-tertiary);
}

::-webkit-scrollbar-corner {
  background: transparent;
}

/* === TABLE — Compact === */
.nexo-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
}

.nexo-table thead th {
  text-align: left;
  font-size: 0.625rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--text-tertiary);
  padding: 0.375rem 0.75rem;
  border-bottom: 1px solid var(--border);
  background: var(--bg-card);
  position: sticky;
  top: 0;
  z-index: 1;
}

.nexo-table tbody tr {
  transition: background-color 100ms ease;
  cursor: pointer;
}

.nexo-table tbody tr:hover {
  background-color: rgba(255, 255, 255, 0.02);
}

.nexo-table tbody tr.selected {
  background-color: rgba(222, 53, 13, 0.06);
  border-left: 2px solid var(--primary);
}

.nexo-table tbody td {
  padding: 0.5rem 0.75rem;
  border-bottom: 1px solid rgba(36, 36, 36, 0.5);
  font-size: 0.75rem;
}

/* === INPUTS — Compact === */
.nexo-input {
  background: var(--bg-dark);
  border: 1px solid var(--border);
  color: var(--text-primary);
  padding: 6px 10px;
  border-radius: 4px;
  font-size: 0.8125rem;
  font-family: 'Inter', sans-serif;
  transition: border-color 150ms ease, background 150ms ease;
  width: 100%;
}

.nexo-input:focus {
  outline: none;
  border-color: var(--primary);
  background: var(--bg-surface);
}

.nexo-input::placeholder {
  color: var(--text-tertiary);
}

textarea.nexo-input {
  resize: vertical;
  min-height: 60px;
  font-family: 'Inter', sans-serif;
}

/* === BUTTONS — Minimal === */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.375rem;
  padding: 0.375rem 0.75rem;
  border-radius: 4px;
  cursor: pointer;
  transition: all 100ms ease;
  border: none;
  outline: none;
  font-weight: 500;
  font-size: 0.75rem;
  font-family: 'Inter', sans-serif;
  white-space: nowrap;
}

.btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.btn-primary {
  background: var(--primary);
  color: white;
}

.btn-primary:hover:not(:disabled) {
  background: var(--primary-dark);
}

.btn-secondary {
  background: var(--accent);
  color: white;
}

.btn-outline {
  background: var(--bg-surface);
  border: 1px solid var(--border);
  color: var(--text-primary);
}

.btn-outline:hover:not(:disabled) {
  background: var(--bg-elevated);
  border-color: var(--border-light);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
}

.btn-ghost:hover:not(:disabled) {
  color: var(--text-primary);
}

/* === STATUS DOTS === */
.status-dot {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot.active { background: var(--success); }
.status-dot.warning { background: var(--warning); }
.status-dot.error { background: var(--error); }
.status-dot.offline { background: #6B6B6B; }

/* === Mono font for data === */
.font-mono-data {
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  font-size: 0.75rem;
}

/* === Transitions — Minimal === */
* {
  transition: background-color var(--transition-duration, 150ms) ease,
              color var(--transition-duration, 150ms) ease,
              border-color var(--transition-duration, 150ms) ease;
}
